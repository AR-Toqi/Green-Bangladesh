<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verification Code</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            line-height: 1.6;
            color: #333;
            background-color: #f4f7f6;
            padding: 20px;
        }
        .container {
            max-width: 600px;
            margin: 0 auto;
            background-color: #ffffff;
            padding: 40px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        .header {
            text-align: center;
            border-bottom: 2px solid #2ecc71;
            padding-bottom: 20px;
            margin-bottom: 20px;
        }
        .header h1 {
            color: #2ecc71;
            margin: 0;
        }
        .content {
            margin-bottom: 30px;
            text-align: center;
        }
        .otp-code {
            display: inline-block;
            padding: 15px 30px;
            font-size: 32px;
            letter-spacing: 5px;
            font-weight: bold;
            color: #2c3e50;
            background-color: #ecf0f1;
            border-radius: 10px;
            margin: 20px 0;
            border: 1px dashed #2ecc71;
        }
        .footer {
            text-align: center;
            font-size: 0.8em;
            color: #777;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>Green Bangladesh</h1>
        </div>
        <div class="content">
            <p>Hi <%= name %>,</p>
            <p>Your verification code is:</p>
            <div class="otp-code"><%= otp %></div>
            <p>This code will expire in 2 minutes. If you did not request this, please ignore this email.</p>
        </div>
        <div class="footer">
            <p>Admin, Green Bangladesh</p>
            <p>&copy; 2026-PRESENT Green Bangladesh. All rights reserved.</p>
        </div>
    </div>
</body>
</html>
